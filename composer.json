{
    "name": "rmsstuttgart/rms-ai-search",
    "type": "typo3-cms-extension",
    "description": "AI Search extension for TYPO3 - connect your TYPO3 to https://chat.rm-solutions.de/",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Michael Kettel",
            "role": "Developer",
            "homepage": "https://rm-solutions.de"
        }
    ],
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require": {
        "typo3/cms-core": "^13.4",
        "typo3/cms-install": "^13.4",
        "typo3/cms-backend": "^13.4",
        "typo3/cms-frontend": "^13.4",
        "typo3/cms-extbase": "^13.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "cakephp/cakephp-codesniffer": "^5.0",
        "squizlabs/php_codesniffer": "^3.7",
        "ssch/typo3-rector": "^3"
    },
    "autoload": {
        "psr-4": {
            "Rmsstuttgart\\RmsAiSearch\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "rms_ai_search"
        }
    }
}